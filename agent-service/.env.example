# Service identity
SERVICE_NAME=agent-service
SERVICE_VERSION=1.0.0
ENV=dev
LOG_LEVEL=INFO

# Timeouts
REQUEST_TIMEOUT_S=30
CLIENT_TIMEOUT_S=4
CLIENT_RETRIES=1
MAX_REPAIR_ATTEMPTS=2
BLOCK_VIOLATION_THRESHOLD=3

# LLM (Vertex Gemini)
LLM_PROVIDER=mock
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash

# Storage
# Local dev Postgres can run on 127.0.0.1:5433 if 5432 is busy.
DATABASE_URL=sqlite:///./agent_service.db

# Downstream services
KNOWLEDGE_SERVICE_URL=http://knowledge-service:8000
WORKFLOW_SERVICE_URL=http://workflow-service:8000
GOVERNANCE_SERVICE_URL=http://governance-service:8000
USE_MOCK_SERVICES=true
